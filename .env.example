# ─────────────────────────────────────────────
# VM-Tippning 2026 — Environment Variables
# Copy to .env.local for local development.
# All secrets are set via AWS Amplify Environment Variables in production.
# NEVER commit .env.local or any file with real secrets.
# ─────────────────────────────────────────────

# ── Database ───────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public&sslmode=require
DATABASE_URL="postgresql://postgres:changeme@localhost:5432/tipsy?schema=public"

# ── NextAuth ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_SECRET"

# Production: your actual domain, e.g. https://tipsy.example.com
# Development: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# ── AWS SES (Email) ────────────────────────────────────────────────────────────
# SES SMTP credentials from AWS Console → SES → SMTP Settings
EMAIL_SERVER_HOST="email-smtp.eu-north-1.amazonaws.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_SECURE="false"
# Create SMTP credentials via IAM (NOT your AWS access key)
EMAIL_SERVER_USER="REPLACE_WITH_SES_SMTP_USER"
EMAIL_SERVER_PASSWORD="REPLACE_WITH_SES_SMTP_PASSWORD"
EMAIL_FROM="VM-Tipset 2026 <noreply@yourdomain.com>"

# ── Admin seed (used only during `db:seed`) ────────────────────────────────────
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="REPLACE_WITH_STRONG_PASSWORD"

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV="development"
